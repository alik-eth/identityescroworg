# Copy to .env and fill in as needed. .env is gitignored at the repo root.
#
# The docker-compose harness hardcodes anvil's deterministic first
# account for the deployer; the only knobs below are for *host-side*
# workflows (pnpm -F @qkb/web dev, anvil-forking Sepolia, etc.)

# Chain RPC override used by the `qie-cli` and `@qkb/web` dev servers
# when they talk to the same anvil the harness spins up.
QIE_RPC_URL=http://localhost:8545

# QKBRegistry address — populated by `deployer` into ./shared/local.json
# (named volume). Consume it from there; do not hardcode.
# QIE_REGISTRY_ADDRESS=0x...

# Optional: pumped trusted-cas.json path if you want the agents to run
# with the full LOTL-backed CAdES verifier enabled.
# QIE_TRUSTED_CAS_PATH=/absolute/path/to/trusted-cas.json

# Leave unset in dev. Set to "1" to reproduce the legacy Phase-1
# (ungated) release path. docker-compose.yml currently sets this for
# each agent because no arbitrator contract is wired yet.
# STATE_READER_DISABLED=1
