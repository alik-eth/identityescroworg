# syntax=docker/dockerfile:1.7
#
# Minimal production image for @qkb/qie-agent.
#
# Assumes pnpm build ran on the host — we DO NOT run pnpm/tsc inside the
# image. The build context is the monorepo root. Required inputs:
#   - packages/qie-core/{package.json,dist}     (built)
#   - packages/qie-agent/{package.json,dist}    (built)
#   - node_modules/ for both packages (hoisted via pnpm workspace)
#
# Healthcheck hits /.well-known/qie-agent.json on the listening port.

FROM docker.io/library/node:20-alpine

RUN apk add --no-cache curl \
  && addgroup -S qie && adduser -S qie -G qie

WORKDIR /app

# Workspace manifests (needed so node can resolve the workspace:* link).
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY packages/qie-core/package.json ./packages/qie-core/package.json
COPY packages/qie-agent/package.json ./packages/qie-agent/package.json

# Built JS + type declarations.
COPY packages/qie-core/dist ./packages/qie-core/dist
COPY packages/qie-agent/dist ./packages/qie-agent/dist

# Hoisted deps (copy the entire node_modules — alpine image is small enough
# and pnpm's symlink layout is load-bearing for workspace:* resolution).
COPY node_modules ./node_modules
COPY packages/qie-core/node_modules ./packages/qie-core/node_modules
COPY packages/qie-agent/node_modules ./packages/qie-agent/node_modules

RUN mkdir -p /data/escrow && chown -R qie:qie /data /app
USER qie

EXPOSE 8080

ENV QIE_AGENT_PORT=8080
ENV QIE_AGENT_HOST=0.0.0.0
ENV QIE_AGENT_STORAGE=/data/escrow

HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -fsS "http://127.0.0.1:${QIE_AGENT_PORT:-8080}/.well-known/qie-agent.json" || exit 1

CMD ["node", "packages/qie-agent/dist/bin/qie-agent.js", "serve"]
