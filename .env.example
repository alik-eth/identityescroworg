# Circuits ceremony → Cloudflare R2 artifact hosting.
# Free tier: 10 GB storage + 0 egress fees (covers Phase 1 zkey + wasm).
# NEVER commit a real .env file — only .env.example.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Contracts deployment — dev key for Sepolia / anvil.
# Real value lives in repo-root .env (untracked). NEVER commit.
ADMIN_PRIVATE_KEY=
ADMIN_ADDRESS=
# Sepolia RPC + Etherscan for deploy + verify:
SEPOLIA_RPC_URL=
ETHERSCAN_KEY=
# On-chain addresses set at deploy time:
REGISTRY_ADDR=
ROOT_TL=
# Optional: pre-deployed real verifier addresses; when empty, Deploy.s.sol
# deploys StubGroth16Verifier instances in their place.
RSA_VERIFIER_ADDR=
ECDSA_VERIFIER_ADDR=

# Web runtime — public R2 URLs produced by circuits upload step.
# These are PUBLIC hosted files; safe to hard-code or distribute.
QKB_PROVER_WASM_URL_RSA=
QKB_PROVER_ZKEY_URL_RSA=
QKB_PROVER_WASM_URL_ECDSA=
QKB_PROVER_ZKEY_URL_ECDSA=
