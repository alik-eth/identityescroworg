# Contributor env — copy to contrib.env and fill in every field before running launch.sh.
# contrib.env is gitignored.  Never commit it.

# Your Fly app handle (letters, numbers, hyphens).
# The app will be named zkqes-ceremony-<handle>.
CONTRIBUTOR_HANDLE=your-handle

# Round number (positive integer, assigned by the coordinator).
ROUND=1

# URLs provided by the coordinator in your DM.
PREV_ROUND_URL=https://prove.zkqes.org/ceremony/rounds/round-0.zkey
R1CS_URL=https://prove.zkqes.org/ceremony/zkqes-v5.r1cs
PTAU_URL=https://prove.zkqes.org/ceremony/pot/pot23.ptau
SIGNED_PUT_URL=<your-signed-upload-url>

# Public attestation name (appears in the public contribution log).
CONTRIBUTOR_NAME=Your Name

# 32-byte hex entropy — generated on YOUR machine (see README.md §3).
# This is the one piece of randomness that comes from you, not Fly.
# Generate with:  openssl rand -hex 32
CONTRIBUTOR_ENTROPY=

# Optional: override the default Frankfurt region.
# FLY_REGION=fra
