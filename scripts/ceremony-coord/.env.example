# R2 (Cloudflare) credentials — admin-only.
# Generated at: Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create.
# Scope: Read & Write on bucket `prove-zkqes-org`.
#
# IMPORTANT: Founder must provision the `prove-zkqes-org` R2 bucket and the
# `prove.zkqes.org` DNS subdomain before the next ceremony run. The old
# `prove-identityescrow-org` bucket / `prove.identityescrow.org` subdomain
# remain read-only for V3/V4 historical artifacts and must NOT be written to.
# See specs/2026-05-03-zkqes-rename-design.md §1.Q5.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prove-zkqes-org
R2_PUBLIC_BASE=https://prove.zkqes.org

# Production circuit artifacts — used by verify-contribution.ts and round-zero.ts.
# Absolute paths (or relative to scripts/ceremony-coord/).
PROD_R1CS_PATH=
PROD_PTAU_PATH=
