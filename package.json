{
  "name": "zkqes",
  "version": "0.0.0",
  "private": true,
  "description": "zkqes — a zero-knowledge proof of a qualified electronic signature (eIDAS QES).",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "flatten": "pnpm --filter @qkb/lotl-flattener run cli",
    "binding:admin": "node --import tsx packages/web/scripts/build-admin-binding.mjs",
    "verify:real-qes": "node --import tsx packages/web/scripts/verify-real-qes.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.5.0"
  }
}
