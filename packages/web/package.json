{
  "name": "@qkb/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173 --strictPort --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "package": "pnpm run build && node scripts/pack.mjs",
    "deploy:fly": "cd ../.. && flyctl deploy --config packages/web/fly.toml --dockerfile packages/web/Dockerfile",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^1.4.0",
    "@noble/secp256k1": "^2.1.0",
    "@qkb/qie-agent": "workspace:*",
    "@qkb/qie-core": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-router": "^1.45.0",
    "asn1js": "^3.0.7",
    "buffer": "^6.0.3",
    "canonicalize": "^3.0.0",
    "circomlibjs": "^0.1.7",
    "i18next": "^23.11.5",
    "pkijs": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "tailwindcss": "^4.2.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.0",
    "node-forge": "^1.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^2.0.0"
  }
}
