{
  "name": "@qkb/cli",
  "version": "0.5.2-pre",
  "private": true,
  "type": "module",
  "description": "QKB CLI server: localhost-bound native rapidsnark prover bridging the V5.2 browser register flow to the on-disk zkey at 13.86 s / 3.70 GiB peak.",
  "bin": {
    "qkb": "./dist/qkb.cjs"
  },
  "scripts": {
    "build": "tsc",
    "build:bin": "tsc && pkg . --targets node20-linux-x64,node20-macos-arm64,node20-macos-x64,node20-linux-arm64,node20-win-x64 --output dist/qkb",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
