{
  "name": "@qkb/qie-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": { "qie-agent": "dist/bin/qie-agent.js" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./browser": { "types": "./dist/browser/index.d.ts", "import": "./dist/browser/index.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin/qie-agent.js"
  },
  "dependencies": {
    "@qkb/qie-core": "workspace:*",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@noble/post-quantum": "^0.2.1",
    "asn1js": "^3.0.7",
    "fastify": "^4.28.0",
    "pkijs": "^3.4.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-forge": "^1.3.11",
    "jsdom": "^24.1.0",
    "node-forge": "^1.3.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
